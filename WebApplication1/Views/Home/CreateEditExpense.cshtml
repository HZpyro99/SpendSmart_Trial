@{
    ViewData["Title"] = "Create / Edit";
}

@model SpendSmart.Models.Expense

<div class="text-center">
    <h1 class="display-4">Create or edit an expense</h1>
  
</div>

<form asp-action="Forms" asp-controller="Home">

    <input hidden class="form-control" type="number" placeholder="0" asp-for="Id"/>
    <label class="mt-4">Value Php</label>
    <input class="form-control" type="number" placeholder="0" asp-for="Value" step="1.00" />
    <label class="mt-4">Description</label>
    <input class="form-control" type="text" placeholder="Add Description" asp-for="Description"/>

    <button class="btn btn-primary mt-4" type="submit">Submit</button>
</form>   